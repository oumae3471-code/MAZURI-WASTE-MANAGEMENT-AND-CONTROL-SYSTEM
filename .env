# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mazuri
MONGODB_USER=admin
MONGODB_PASSWORD=password
DB_NAME=mazuri

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this_in_production
REFRESH_TOKEN_EXPIRE=30d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Mazuri Waste Management
EMAIL_FROM=noreply@mazuri.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FORMATS=jpg,png,pdf,xlsx,csv
UPLOAD_DIR=./uploads

# Frontend Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Session Configuration
SESSION_SECRET=your_session_secret_key_change_this
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true

# Report Configuration
REPORT_FORMAT=pdf
REPORT_STORAGE_PATH=./reports

# Geolocation Configuration
ENABLE_GPS=true
GPS_ACCURACY_THRESHOLD=50

# Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin Configuration
ADMIN_EMAIL=admin@mazuri.com
ADMIN_PASSWORD=change_this_default_password

# MySQL Configuration (optional)
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=mazuri
MYSQL_USER=mazuri
MYSQL_PASSWORD=mazuri_pass
